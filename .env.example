# Application Configuration
NODE_ENV=production
PORT=3000
APP_URL="https://your-domain.vercel.app"

# PostgreSQL Database (Neon, Supabase, etc.)
# For local development use SQLite: "file:./dev.db"
DATABASE_URL="postgresql://user:password@ep-xxxx.neon.tech/neondb?sslmode=require"

# Microsoft Graph API Configuration (for real email sending)
# Get these from Azure Entra ID app registration
MICROSOFT_TENANT_ID=your_tenant_id_here
MICROSOFT_CLIENT_ID=your_client_id_here
MICROSOFT_CLIENT_SECRET=your_client_secret_here
MICROSOFT_SENDER_EMAIL=hello@yourdomain.com